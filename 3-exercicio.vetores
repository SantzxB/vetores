import os

os.system("cls||clear")

list = []
quantidade_notas = 6
pares = 0
impares = 0
for i in range(quantidade_notas):
    nota = float(input(f"Digite a {i + 1}ª nota:"))
    list.append(nota)

    if nota % 2 == 0:
       pares += 1
    else:
       impares +=1
print(f"Notas: {list}")
print(f"Números pares: {pares}")
print(f"Números ímpares: {impares}")
